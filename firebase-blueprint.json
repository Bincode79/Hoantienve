{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and role management.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "sdt": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "sdt", "role"]
    },
    "RefundRequest": {
      "title": "Refund Request",
      "description": "A request for a flight ticket refund.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who created the request" },
        "userSdt": { "type": "string" },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "accountHolder": { "type": "string" },
        "amount": { "type": "number" },
        "orderCode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "adminNote": { "type": "string" }
      },
      "required": ["userId", "bankName", "accountNumber", "accountHolder", "amount", "orderCode", "status"]
    },
    "BaseData": {
      "title": "Base Data",
      "description": "Master list of valid flight orders for validation.",
      "type": "object",
      "properties": {
        "orderCode": { "type": "string", "description": "PNR code" },
        "amount": { "type": "number", "description": "Original ticket amount" },
        "passengerName": { "type": "string" },
        "flightNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["valid", "refunded", "cancelled"] }
      },
      "required": ["orderCode", "amount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/refundRequests/{requestId}": {
      "schema": "RefundRequest",
      "description": "Refund requests submitted by users"
    },
    "/basedata/{orderId}": {
      "schema": "BaseData",
      "description": "Master list of flight orders"
    }
  }
}
