# ─── Application ────────────────────────────────────────────────────────────────
APP_URL="http://localhost:5173"
NODE_ENV="development"

# ─── Neon Database ─────────────────────────────────────────────────────────────
# Direct connection (bỏ -pooler để tránh lỗi pg_session_jwt)
DATABASE_URL="postgresql://user:password@ep-xxx.xxx.aws.neon.tech/neondb?sslmode=require"

# ─── JWT Auth ──────────────────────────────────────────────────────────────────
# JWT secret cho server-side token signing (tối thiểu 32 ký tự)
# Tạo secret mới: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-64-char-hex-secret-here"
JWT_EXPIRES_IN="7d"

# ─── Firebase (Optional - for push notifications) ────────────────────────────────
FIREBASE_SERVICE_ACCOUNT=
VITE_FCM_VAPID_KEY=

# ─── AI (Optional - for chat features) ─────────────────────────────────────────
GEMINI_API_KEY=
